# PMO Platform — ML Training Credentials
# Copy this file to .env and fill in the service_role key.
# .env is gitignored — never commit it.
#
# WHY service_role and not anon?
#   The anon key respects Row Level Security (RLS). Without an authenticated
#   user session, RLS blocks all table reads. The training script runs locally
#   with no user session, so it needs the service_role key, which bypasses RLS
#   at the connection level. This is the correct pattern for server-side scripts.
#
#   NEVER put service_role in the React/Vite frontend. It belongs only here,
#   in scripts that run on your local machine or a trusted server.
#
# WHERE TO GET IT:
#   1. Go to https://app.supabase.com/project/qffzpdhnrkfbkzgrnvsy/settings/api
#   2. Under "Project API keys" -> find "service_role" row
#   3. Click Reveal -> Copy

SUPABASE_URL=https://qffzpdhnrkfbkzgrnvsy.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
