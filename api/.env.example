# PMO Platform FastAPI — Environment Variables
# Copy to .env for local development. Set these in Railway dashboard for production.
# NEVER commit .env with real values.

# Supabase
SUPABASE_URL=https://qffzpdhnrkfbkzgrnvsy.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-settings-api
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-supabase-settings-api

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# Environment
ENVIRONMENT=development
